# This file tells Git which generated, local, and secret files to ignore.
# It keeps build outputs, virtual envs, and sensitive config out of commits.

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Virtual env
venv/
.env/
.venv/

# Environment variables - IMPORTANT: Never commit .env files!
.env
.env.local
.env.*.local

# Editor stuff
.vscode/
.idea/

# Frontend / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.pnp
frontend/.pnp.js
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.pem

# Data / uploads
data/
uploads/
*.pdf
*.mp3
*.wav
*.pptx
*.ppt

# OS
.DS_Store
Thumbs.db
